# ─── Base de Datos ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario@localhost:5432/alquiladora_crystal

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Meta / WhatsApp Business API ─────────────────────────────────────────────
# Token de acceso permanente de tu App en Meta Developers
WHATSAPP_TOKEN=EAAxxxxxxx

# Token que configuras en Meta Developers > Webhooks > Verify Token
WHATSAPP_VERIFY_TOKEN=mi_token_secreto

# ID del número de teléfono registrado en Meta (viene en los mensajes entrantes)
WHATSAPP_PHONE_NUMBER_ID=1234567890

# ─── Negocio ──────────────────────────────────────────────────────────────────
# UUID del registro en la tabla 'negocios' (créalo primero con SQL o un seed)
NEGOCIO_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Archivos ─────────────────────────────────────────────────────────────────
PDF_DIR=pdf
LOGO_PATH=assets/logo.png
EXCEL_TEMPLATE_PATH=assets/Nota.xlsx
LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice

# ─── Teléfonos bloqueados (separados por coma, sin espacios) ──────────────────
BLOCKED_PHONES=5212212664376,5215512345678
